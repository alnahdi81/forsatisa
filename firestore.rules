rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all read/write for now to resolve submission issues
    match /jobs/{job} {
      allow read, write: if true;
    }
    match /ads/{ad} {
      allow read, write: if true;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
