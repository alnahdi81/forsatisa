rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == "noamksa8@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Job
    function isValidJob(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'createdAt', 'status'])
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 10000
        && data.category in ['military', 'remote', 'company', 'government', 'university', 'training', 'employment_training']
        && data.status in ['active', 'soon', 'expiring', 'expired']
        && data.createdAt is timestamp
        && (data.get('company', null) == null || (data.company is string && data.company.size() <= 200))
        && (data.get('location', null) == null || (data.location is string && data.location.size() <= 200))
        && (data.get('image', null) == null || (data.image is string && data.image.size() <= 2000))
        && (data.get('externalLink', null) == null || (data.externalLink is string && data.externalLink.size() <= 2000));
    }

    // Validation for Ad
    function isValidAd(data) {
      return data.keys().hasAll(['title', 'image', 'position', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.image is string && data.image.size() <= 2000
        && data.position in ['home_hero', 'sidebar', 'job_detail']
        && data.createdAt is timestamp
        && (data.get('link', null) == null || (data.link is string && data.link.size() <= 2000));
    }

    // Job collection rules
    match /jobs/{jobId} {
      allow read: if true; // Public access for search engines and visitors
      allow create: if isAdmin() && isValidId(jobId) && isValidJob(incoming());
      allow update: if isAdmin() && isValidJob(incoming());
      allow delete: if isAdmin();
    }

    // Ad collection rules
    match /ads/{adId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(adId) && isValidAd(incoming());
      allow update: if isAdmin() && isValidAd(incoming());
      allow delete: if isAdmin();
    }

    // Subscription rules
    match /subscriptions/{subId} {
      allow create: if incoming().keys().hasAll(['email', 'createdAt'])
                    && incoming().email is string && incoming().email.size() <= 200 
                    && incoming().createdAt == request.time;
      allow read, delete: if isAdmin();
    }
  }
}
