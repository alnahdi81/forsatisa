{
  "entities": {
    "Job": {
      "title": "Job Posting",
      "description": "Details of a job requirement.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Job title" },
        "description": { "type": "string", "description": "Detailed job description" },
        "company": { "type": "string", "description": "Hiring company or entity" },
        "category": { 
          "type": "string", 
          "enum": ["military", "remote", "company", "government", "university", "training", "employment_training"],
          "description": "Type of job" 
        },
        "location": { "type": "string", "description": "Job location" },
        "image": { "type": "string", "description": "Job image or logo URL" },
        "createdAt": { "type": "string", "format": "date-time" },
        "externalLink": { "type": "string", "description": "Link to apply" },
        "status": {
          "type": "string",
          "enum": ["active", "soon", "expiring", "expired"],
          "description": "Current status of the job posting"
        }
      },
      "required": ["title", "description", "category", "createdAt", "status"]
    },
    "Ad": {
      "title": "Advertisement",
      "description": "Ad banners and info.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Ad title" },
        "image": { "type": "string", "description": "Banner image URL" },
        "link": { "type": "string", "description": "Target URL" },
        "position": { 
          "type": "string", 
          "enum": ["home_hero", "sidebar", "job_detail"],
          "description": "Where to show the ad" 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "image", "position", "createdAt"]
    },
    "Subscription": {
      "title": "Email Subscription",
      "description": "User subscription for alerts.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Subscriber email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Admin": {
      "title": "Administrator",
      "description": "Authorized users for the dashboard.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Admin email" },
        "name": { "type": "string", "description": "Admin name" },
        "role": { "type": "string", "enum": ["owner", "employee"], "description": "Admin role" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "addedAt"]
    }
  },
  "firestore": {
    "jobs": {
      "schema": "Job",
      "description": "List of all active job postings."
    },
    "ads": {
      "schema": "Ad",
      "description": "Managed advertisements for the platform."
    },
    "subscriptions": {
      "schema": "Subscription",
      "description": "User emails for newsletter/alerts."
    },
    "admins": {
      "schema": "Admin",
      "description": "User emails authorized to access the admin dashboard."
    }
  }
}
